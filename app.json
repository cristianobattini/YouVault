{
  "expo": {
    "name": "YouVault",
    "slug": "YouVault",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "youvault",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cristiano.youvault",
      "icon": "./assets/images/icon.png",
      "infoPlist": {
        "NSFaceIDUsageDescription": "YouVault uses Face ID to protect your credentials."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#208AEF",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "package": "com.cristiano.youvault"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-local-authentication",
      "expo-secure-store",
      "expo-sharing",
      "expo-asset",
      "expo-document-picker",
      "expo-font",
      "expo-web-browser",
      "expo-status-bar",
      "expo-image"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
